class Solution:
    def shortestPalindrome(self, s: str) -> str:
        if not s:
            return ""
        
        # Combine string with its reverse and a separator
        # The separator '#' ensures we only match the prefix of s
        combined = s + "#" + s[::-1]
        
        # Build the KMP LPS (Longest Prefix Suffix) array
        lps = [0] * len(combined)
        for i in range(1, len(combined)):
            j = lps[i - 1]
            while j > 0 and combined[i] != combined[j]:
                j = lps[j - 1]
            if combined[i] == combined[j]:
                j += 1
            lps[i] = j
        
        # Length of the longest palindromic prefix
        longest_pal_len = lps[-1]
        
        # The part that needs to be reversed and added to the front
        suffix_to_reverse = s[longest_pal_len:]
        return suffix_to_reverse[::-1] + s
