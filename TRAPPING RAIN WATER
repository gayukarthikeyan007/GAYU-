from typing import List

class Solution:
    def trap(self, height: List[int]) -> int:
        if not height:
            return 0
            
        left, right = 0, len(height) - 1
        left_max, right_max = height[left], height[right]
        water_trapped = 0
        
        while left < right:
            # We process the side with the smaller maximum height 
            # because that side limits the water level.
            if left_max < right_max:
                left += 1
                # Update current left_max
                left_max = max(left_max, height[left])
                # Water trapped at current left = left_max - height[left]
                water_trapped += left_max - height[left]
            else:
                right -= 1
                # Update current right_max
                right_max = max(right_max, height[right])
                # Water trapped at current right = right_max - height[right]
                water_trapped += right_max - height[right]
                
        return water_trapped
