from collections import defaultdict, OrderedDict

class LFUCache:
    def __init__(self, capacity: int):
        self.capacity = capacity
        self.min_freq = 0
        # key -> (value, frequency)
        self.key_data = {}
        # frequency -> OrderedDict(key -> None)
        self.freq_map = defaultdict(OrderedDict)

    def _update(self, key, freq):
        """Helper to move a key to the next frequency bucket."""
        # Remove from current frequency bucket
        self.freq_map[freq].pop(key)
        if not self.freq_map[freq] and freq == self.min_freq:
            self.min_freq += 1
            
        # Add to the next frequency bucket (mark as most recent)
        new_freq = freq + 1
        self.freq_map[new_freq][key] = None
        self.key_data[key][1] = new_freq

    def get(self, key: int) -> int:
        if key not in self.key_data:
            return -1
        
        val, freq = self.key_data[key]
        self._update(key, freq)
        return val

    def put(self, key: int, value: int) -> None:
        if self.capacity <= 0:
            return

        if key in self.key_data:
            self.key_data[key][0] = value
            self._update(key, self.key_data[key][1])
        else:
            if len(self.key_data) >= self.capacity:
                # Evict: LFU (min_freq), then LRU (popitem(last=False))
                pop_key, _ = self.freq_map[self.min_freq].popitem(last=False)
                del self.key_data[pop_key]
            
            # Insert new key
            self.key_data[key] = [value, 1]
            self.freq_map[1][key] = None
            self.min_freq = 1
