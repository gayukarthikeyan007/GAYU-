from collections import deque
from typing import List

class Solution:
    def maxSlidingWindow(self, nums: List[int], k: int) -> List[int]:
        res = []
        # Stores indices of nums in decreasing order of their values
        q = deque() 
        
        for i, n in enumerate(nums):
            # 1. Remove elements smaller than the current element from the back
            # (Ensures the deque is always in decreasing order)
            while q and nums[q[-1]] < n:
                q.pop()
            
            q.append(i)
            
            # 2. Remove the front element if it's outside the current window
            if q[0] == i - k:
                q.popleft()
            
            # 3. Once the first window is complete, add the front of q to results
            if i >= k - 1:
                res.append(nums[q[0]])
                
        return res

        
