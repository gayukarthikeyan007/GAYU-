class Solution:
    def getPermutation(self, n: int, k: int) -> str:
        import math
        numbers = [str(i) for i in range(1, n + 1)]
        fact = math.factorial(n - 1)
        k -= 1
        res = []
        
        for i in range(n - 1, -1, -1):
            idx = k // fact
            res.append(numbers.pop(idx))
            k %= fact
            if i > 0:
                fact //= i
                
        return "".join(res)
